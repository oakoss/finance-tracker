{
  "[dockercompose]": {
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.insertSpaces": true,
    "editor.quickSuggestions": {
      "comments": false,
      "other": true,
      "strings": true
    },
    "editor.tabSize": 2
  },
  "[javascript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "[markdown]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[yaml]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "editor.codeActionsOnSave": { "source.fixAll.oxc": "always" },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.quickSuggestions": { "strings": "on" },
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "files.readonlyInclude": {
    "**/.tanstack/**/*": true,
    "**/routeTree.gen.ts": true,
    "pnpm-lock.yaml": true
  },
  "files.watcherExclude": {
    "**/.tanstack/**/*": true,
    "**/routeTree.gen.ts": true,
    "pnpm-lock.yaml": true
  },
  "js/ts.preferences.autoImportFileExcludePatterns": [
    "@base-ui/react",
    "@react-email/components",
    "^lucide-react/dist/lucide-react.suffixed$",
    "posthog-js/react",
    "radix-ui",
    "react-day-picker",
    "recharts",
    "sonner"
  ],
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": ["^(node:)?os$"],
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "oxc.configPath": ".oxlintrc.json",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.path.oxfmt": "./node_modules/.bin/oxfmt",
  "oxc.typeAware": true,
  "prettier.enable": false,
  "search.exclude": {
    "**/.tanstack/**/*": true,
    "**/routeTree.gen.ts": true,
    "pnpm-lock.yaml": true
  }
}
