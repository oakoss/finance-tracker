{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"],
      "~e2e/*": ["./e2e/*"],
      "~test/*": ["./test/*"]
    }
  },
  "include": ["./**/*.ts"]
}
