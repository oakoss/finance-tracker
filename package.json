{
  "name": "finance-tracker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf node_modules .output dist pnpm-lock.yaml",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:seed": "pnpm with:env tsx test/seed/seed-runner.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "vite dev",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f db",
    "docker:reset": "docker compose down -v",
    "docker:up": "docker compose up -d",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint --max-warnings 0 --cache --cache-location node_modules/.cache/eslint/.eslintcache .",
    "lint:fix": "eslint --max-warnings 0 --fix --cache --cache-location node_modules/.cache/eslint/.eslintcache .",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md'",
    "paraglide:compile": "pnpm exec paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "preview": "vite preview",
    "schema:auth": "pnpm schema:auth:generate && pnpm schema:auth:postprocess && eslint --fix src/modules/auth/db/schema.ts && oxfmt src/modules/auth/db/schema.ts",
    "schema:auth:generate": "pnpm with:env pnpm dlx @better-auth/cli generate --config src/lib/auth/server.ts --output src/modules/auth/db/schema.ts --yes",
    "schema:auth:postprocess": "tsx scripts/postprocess-auth-schema.ts",
    "start": "pnpm with:env node .output/server/index.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --project unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "vitest run --project integration",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "with:env": "dotenvx run --"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@better-auth/drizzle-adapter": "^1.5.4",
    "@date-fns/tz": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@getbrevo/brevo": "^4.0.1",
    "@headless-tree/core": "^1.6.3",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@react-email/tailwind": "^2.0.5",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-hotkeys": "^0.4.0",
    "@tanstack/react-pacer": "^0.20.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.6",
