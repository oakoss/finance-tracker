{
  "name": "finance-tracker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf node_modules .output dist pnpm-lock.yaml",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:seed": "pnpm with:env tsx test/seed/seed-runner.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "vite dev",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f db",
    "docker:reset": "docker compose down -v",
    "docker:up": "docker compose up -d",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint -c .oxlintrc.json && eslint --max-warnings 0 --cache --cache-location node_modules/.cache/eslint/.eslintcache .",
    "lint:fix": "oxlint -c .oxlintrc.json --fix --fix-suggestions && eslint --max-warnings 0 --fix --cache --cache-location node_modules/.cache/eslint/.eslintcache .",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md'",
    "paraglide:compile": "pnpm exec paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "preview": "vite preview",
    "schema:auth": "pnpm schema:auth:generate && pnpm schema:auth:postprocess && eslint --fix src/modules/auth/db/schema.ts && oxfmt src/modules/auth/db/schema.ts",
    "schema:auth:generate": "pnpm with:env pnpm dlx @better-auth/cli generate --config src/lib/auth/server.ts --output src/modules/auth/db/schema.ts --yes",
    "schema:auth:postprocess": "tsx scripts/postprocess-auth-schema.ts",
    "start": "pnpm with:env node .output/server/index.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --project unit",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:demo": "playwright test --project=chromium:demo",
    "test:e2e:smoke": "playwright test --grep @smoke --project=chromium:authenticated --project=chromium:public",
    "test:e2e:stress": "playwright test --project=stress",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "vitest run --project integration",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "with:env": "dotenvx run --"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@date-fns/tz": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@getbrevo/brevo": "^5.0.1",
