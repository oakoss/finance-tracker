    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-arktype": "^0.1.3",
    "drizzle-orm": "^0.45.1",
    "evlog": "^2.9.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
