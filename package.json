    "drizzle-arktype": "^0.1.3",
    "drizzle-orm": "^0.45.1",
    "evlog": "^2.4.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-phone-number-input": "^3.4.16",
