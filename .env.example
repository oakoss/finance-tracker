# =============================================================================
# Auth (Better Auth + OAuth)
# =============================================================================
BETTER_AUTH_URL=https://finance.oakoss.dev
BETTER_AUTH_SECRET=dev-secret-32-characters-long-min
TRUSTED_ORIGINS=https://finance.oakoss.dev,http://localhost:3000
GITHUB_CLIENT_ID=test-github-id
GITHUB_CLIENT_SECRET=test-github-secret
GOOGLE_CLIENT_ID=test-google-id
GOOGLE_CLIENT_SECRET=test-google-secret

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgres://finance_tracker:finance_tracker_password@localhost:5432/finance_tracker_dev

# =============================================================================
# Email — local dev uses Mailpit (SMTP); production uses Brevo API
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=no-reply@finance.oakoss.dev
EMAIL_FROM_NAME=Finance Tracker
EMAIL_REPLY_TO=support@financial.oakoss.dev

# Production only — not needed when SMTP_HOST is set
# BREVO_API_KEY=

# =============================================================================
# Logging (evlog + SigNoz)
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otelcollectorhttp-finance-tracker.jacebabin.com
# OTEL_SERVICE_NAME=finance-tracker
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development
LOG_HASH_SECRET=dev-secret-32-characters-long-min

# =============================================================================
# PostHog Analytics (optional — no-ops when unset)
# =============================================================================
# POSTHOG_API_KEY=phc_xxx (server-side — same project key, not exposed to browser)
# POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# Client (VITE_* — exposed to browser)
# =============================================================================
VITE_CLIENT_LOG_LEVEL=warn
# VITE_PUBLIC_POSTHOG_KEY=phc_xxx
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# E2E Testing (Playwright)
# =============================================================================
E2E_USER_EMAIL=e2e@test.local
E2E_USER_PASSWORD=E2ePassword1!

# =============================================================================
# Docker Compose (local only — not validated by app)
# =============================================================================
POSTGRES_USER=finance_tracker
POSTGRES_PASSWORD=finance_tracker_password
POSTGRES_DB=finance_tracker_dev
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=/var/lib/postgresql/data
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
